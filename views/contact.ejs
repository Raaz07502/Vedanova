<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Vedanova · Contact</title>
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz@14..32&family=Bebas+Neue&display=swap" rel="stylesheet" />
  <!-- Bootstrap 5 (minimal) -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" />
  <!-- Font Awesome 6 -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background: linear-gradient(145deg, #f0f6ff 0%, #e6edf7 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
    }

    .contact-wrapper {
      width: 100%;
      max-width: 1280px;
      margin: 0 auto;
    }

    .contact-container {
      display: grid;
      grid-template-columns: 1.3fr 0.9fr;
      gap: 2rem;
      align-items: stretch;
      width: 100%;
    }

    .card-glass {
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(2px);
      border-radius: 2.2rem;
      box-shadow: 0 20px 50px -12px rgba(0, 20, 60, 0.18), 0 0 0 1px rgba(255, 255, 255, 0.5);
      padding: 2.2rem 2.5rem;
      transition: transform 0.25s ease, box-shadow 0.3s ease;
      border: 1px solid rgba(255, 255, 255, 0.6);
    }

    .card-glass:hover {
      box-shadow: 0 30px 65px -16px rgba(26, 67, 143, 0.25);
      transform: translateY(-3px);
    }

    .contact-form-card {
      display: flex;
      flex-direction: column;
    }

    .contact-info-card {
      display: flex;
      flex-direction: column;
      justify-content: center;
      background: rgba(255, 255, 255, 0.92);
    }

    .form-card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.6rem;
      flex-wrap: wrap;
      gap: 0.5rem 1rem;
    }

    .brand {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2.1rem;
      letter-spacing: 1.5px;
      color: #0a2540;
      line-height: 1;
    }
    .brand span {
      color: #1a5cff;
    }

    .inquiry-badge {
      background: linear-gradient(135deg, #1a5cff, #0d47d1);
      color: #fff;
      font-size: 0.7rem;
      font-weight: 700;
      padding: 0.35rem 1.4rem;
      border-radius: 40px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      letter-spacing: 0.6px;
      text-transform: uppercase;
      box-shadow: 0 6px 14px rgba(26, 92, 255, 0.25);
      white-space: nowrap;
    }
    .inquiry-badge i {
      font-size: 0.7rem;
    }

    .contact-form {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      flex: 1;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    /* ===== LABEL STYLES - ALL BOLD ===== */
    .form-group label {
      font-size: 0.65rem;
      font-weight: 700;           /* <--- BOLD */
      text-transform: uppercase;
      letter-spacing: 0.8px;
      color: #1a3a5a;
    }

    /* EXTRA: if you want ONLY "Full Name" bold, add a class */
    .label-bold {
      font-weight: 800 !important;
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
      padding: 0.7rem 1rem;
      border: 1.5px solid #dfe7f0;
      border-radius: 1rem;
      font-size: 0.9rem;
      font-family: 'Inter', sans-serif;
      background: #f9fcff;
      transition: 0.2s ease;
      color: #0b2b42;
      width: 100%;
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      border-color: #1a5cff;
      outline: none;
      box-shadow: 0 0 0 4px rgba(26, 92, 255, 0.08);
      background: #ffffff;
    }

    .form-group input::placeholder,
    .form-group textarea::placeholder {
      color: #9ab0c9;
      font-size: 0.8rem;
    }

    .form-group textarea {
      min-height: 70px;
      resize: vertical;
      border-radius: 1rem;
    }

    .form-actions {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: 0.5rem;
      flex-wrap: wrap;
      gap: 0.8rem;
    }

    .btn-submit {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      background: linear-gradient(135deg, #1a5cff, #0d47d1);
      color: #fff;
      padding: 0.75rem 2.4rem;
      border: none;
      border-radius: 60px;
      font-weight: 700;
      font-size: 0.9rem;
      cursor: pointer;
      transition: 0.25s ease;
      box-shadow: 0 8px 22px -8px rgba(26, 92, 255, 0.4);
    }

    .btn-submit:hover {
      transform: scale(1.02) translateY(-2px);
      box-shadow: 0 14px 30px -10px rgba(26, 92, 255, 0.5);
      background: linear-gradient(135deg, #3b7aff, #1a5cff);
    }

    .quick-response {
      display: flex;
      gap: 1.2rem;
    }
    .quick-response span {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 0.7rem;
      font-weight: 600;
      color: #1a5cff;
    }
    .quick-response span i {
      font-size: 0.75rem;
    }

    .info-card-heading {
      font-family: 'Inter', sans-serif;
      font-weight: 700;
      font-size: 1.8rem;
      color: #0a2540;
      letter-spacing: -0.02em;
      margin-bottom: 0.2rem;
    }

    .info-card-sub {
      font-size: 0.9rem;
      color: #3a5a7a;
      margin-bottom: 1.8rem;
      line-height: 1.5;
    }

    .info-item {
      display: flex;
      gap: 0.9rem;
      align-items: flex-start;
      margin-bottom: 0.9rem;
    }

    .icon-box {
      min-width: 38px;
      width: 38px;
      height: 38px;
      background: linear-gradient(135deg, #e9f0fe, #d7e4fd);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .icon-box i {
      font-size: 1rem;
      color: #1a5cff;
    }

    .info-text .label {
      font-size: 0.6rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      color: #1a5cff;
    }
    .info-text .value {
      font-weight: 500;
      font-size: 0.85rem;
      color: #0b2b42;
      line-height: 1.4;
    }

    .phone-list {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      margin-top: 0.15rem;
    }
    .phone-list .phone {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.8rem;
      font-weight: 500;
      color: #0b2b42;
    }
    .phone-list .phone i {
      color: #1a5cff;
      width: 16px;
      font-size: 0.7rem;
    }
    .badge-247 {
      background: linear-gradient(135deg, #1a5cff, #0d47d1);
      color: #fff;
      font-size: 0.5rem;
      font-weight: 700;
      padding: 0.1rem 0.6rem;
      border-radius: 30px;
      letter-spacing: 0.5px;
      margin-left: 4px;
    }

    .sector-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      margin-top: 0.2rem;
    }
    .sector-tags span {
      background: #eef4ff;
      color: #0a3a6a;
      font-size: 0.65rem;
      font-weight: 600;
      padding: 0.2rem 1rem;
      border-radius: 30px;
      border: 1px solid rgba(26, 92, 255, 0.08);
    }

    .divider-light {
      border: 0;
      border-top: 1.5px solid #e3ebf5;
      margin: 0.7rem 0 0.9rem 0;
      opacity: 0.7;
    }

    @media (max-width: 1024px) {
      .contact-container {
        gap: 1.5rem;
      }
      .card-glass {
        padding: 1.8rem 1.8rem;
      }
    }

    @media (max-width: 900px) {
      .contact-container {
        grid-template-columns: 1fr;
        max-width: 600px;
        margin: 0 auto;
      }
      .contact-form-card {
        max-height: 680px;
      }
      .contact-info-card {
        padding: 1.8rem;
      }
      body {
        padding: 1rem;
      }
    }

    @media (max-width: 600px) {
      .card-glass {
        padding: 1.2rem 1rem;
        border-radius: 1.6rem;
      }
      .form-row {
        grid-template-columns: 1fr;
        gap: 0.6rem;
      }
      .form-card-header {
        flex-direction: column;
        align-items: flex-start;
      }
      .brand {
        font-size: 1.8rem;
      }
      .form-actions {
        flex-direction: column;
        align-items: stretch;
      }
      .btn-submit {
        justify-content: center;
        padding: 0.65rem 1.8rem;
      }
      .quick-response {
        justify-content: center;
      }
      .info-card-heading {
        font-size: 1.5rem;
      }
      .contact-info-card {
        padding: 1.2rem;
      }
      .info-item {
        gap: 0.6rem;
      }
    }

    @media (max-width: 400px) {
      .inquiry-badge {
        font-size: 0.6rem;
        padding: 0.2rem 1rem;
      }
      .form-group input,
      .form-group select,
      .form-group textarea {
        font-size: 0.75rem;
        padding: 0.5rem 0.7rem;
      }
    }
  </style>
</head>
<body>

<div class="contact-wrapper">
  <div class="contact-container">

    <!-- ===== LEFT CARD · FORM ===== -->
    <div class="contact-form-card card-glass">
      <div class="form-card-header">
        <div class="brand"><span>Vedanova</span></div>
        <div class="inquiry-badge">
          <i class="fas fa-paper-plane"></i> Send Inquiry
        </div>
      </div>

      <form class="contact-form">
        <div class="form-row">
          <div class="form-group">
            <!-- "Full Name" label is BOLD by default (font-weight: 700) -->
            <label for="fullName"><i class="fas fa-user me-1" style="color:#1a5cff;"></i> Full Name</label>
            <input type="text" id="fullName" placeholder="e.g. Ananya Sharma" />
          </div>
          <div class="form-group">
            <label for="email"><i class="fas fa-envelope me-1" style="color:#1a5cff;"></i> Email</label>
            <input type="email" id="email" placeholder="you@company.com" />
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="mobile"><i class="fas fa-phone me-1" style="color:#1a5cff;"></i> Mobile</label>
            <input type="tel" id="mobile" placeholder="+91 98765 43210" />
          </div>
          <div class="form-group">
            <label for="organisation"><i class="fas fa-building me-1" style="color:#1a5cff;"></i> Organisation</label>
            <input type="text" id="organisation" placeholder="Dept. / Company" />
          </div>
        </div>

        <div class="form-group">
          <label for="service"><i class="fas fa-cog me-1" style="color:#1a5cff;"></i> Service Interest</label>
          <select id="service">
            <option value="">Select a service...</option>
            <option value="government-advisory">Government Advisory & Project Management</option>
            <option value="contract-drafting">Contract Drafting & Management</option>
            <option value="cyber-security">Cyber Security Consulting</option>
            <option value="hr-consulting">HR Consulting & Workforce Solutions</option>
            <option value="digital-transformation">Digital Transformation & IT Modernization</option>
            <option value="erp-implementation">ERP & Software Implementation</option>
          </select>
        </div>

        <div class="form-group">
          <label for="message"><i class="fas fa-comment me-1" style="color:#1a5cff;"></i> Message</label>
          <textarea id="message" placeholder="Briefly describe your project, goals, or requirement."></textarea>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn-submit">
            <i class="fas fa-paper-plane"></i> Send Inquiry
          </button>
          <div class="quick-response">
            <span><i class="fas fa-bolt"></i> Quick</span>
            <span><i class="fas fa-headset"></i> 24/7</span>
          </div>
        </div>
      </form>
    </div>

    <!-- ===== RIGHT CARD · INFO ===== -->
    <div class="contact-info-card card-glass">
      <h2 class="info-card-heading">Get in touch</h2>
      <p class="info-card-sub">Let's discuss your next project — government, enterprise or innovation.</p>

      <div class="info-item">
        <div class="icon-box"><i class="fas fa-map-pin"></i></div>
        <div class="info-text">
          <div class="label">Address</div>
          <div class="value">238, Royal Krishna Bungalow, Indore, MP - 452010</div>
        </div>
      </div>

      <div class="info-item">
        <div class="icon-box"><i class="fas fa-envelope"></i></div>
        <div class="info-text">
          <div class="label">Email</div>
          <div class="value">contact@Vedanova.in</div>
        </div>
      </div>

      <div class="info-item">
        <div class="icon-box"><i class="fas fa-building"></i></div>
        <div class="info-text">
          <div class="label">Company</div>
          <div class="value">Vedanova</div>
        </div>
      </div>

      <div class="info-item">
        <div class="icon-box"><i class="fas fa-phone-alt"></i></div>
        <div class="info-text">
          <div class="label">Contact Numbers</div>
          <div class="phone-list">
            <div class="phone"><i class="fas fa-phone"></i> +91 96256 51944</div>
            <div class="phone"><i class="fas fa-headset"></i> 24/7 Enterprise Support <span class="badge-247">24/7</span></div>
          </div>
        </div>
      </div>

      <hr class="divider-light" />

      <div class="info-item">
        <div class="icon-box"><i class="fas fa-briefcase"></i></div>
        <div class="info-text">
          <div class="label">Sectors Served</div>
          <div class="sector-tags">
            <span>Central & State Govt</span>
            <span>PSUs</span>
            <span>BFSI</span>
            <span>Enterprise</span>
          </div>
        </div>
      </div>

      <div style="margin-top: 0.6rem; font-size: 0.7rem; color: #4a6a8a; border-top: 1px dashed #dce5f0; padding-top: 0.6rem; display: flex; gap: 1rem; flex-wrap: wrap;">
        <span><i class="fas fa-check-circle" style="color:#1a5cff;"></i> 10+ years of trust</span>
        <span><i class="fas fa-check-circle" style="color:#1a5cff;"></i> Pan-India delivery</span>
        <span><i class="fas fa-check-circle" style="color:#1a5cff;"></i> Govt. empanelled</span>
      </div>
    </div>

  </div>
</div>

</body>
</html>