<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About VedaNova · Innovating Beyond Boundaries</title>
  <!-- Font & Icons -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: #f0f4fa;
      color: #0b1a2e;
      line-height: 1.6;
    }

    .container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* ----- header / hero section (compact, square, with subtle glow) ----- */
    .about-hero {
      background: linear-gradient(135deg, #0a1f33 0%, #1a3f5e 100%);
      color: white;
      padding: 32px 0 28px;
      margin-bottom: 28px;
      box-shadow: 0 12px 40px rgba(10, 30, 50, 0.20);
      position: relative;
      overflow: hidden;
    }

    .about-hero::after {
      content: '';
      position: absolute;
      top: -50%;
      right: -20%;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(143, 203, 255, 0.06) 0%, transparent 70%);
      border-radius: 50%;
      pointer-events: none;
    }

    .about-hero .container {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      position: relative;
      z-index: 1;
    }

    .about-hero .badge {
      display: inline-block;
      background: rgba(255, 255, 255, 0.07);
      backdrop-filter: blur(8px);
      padding: 5px 18px;
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.6px;
      text-transform: uppercase;
      color: #b8d6f5;
      margin-bottom: 14px;
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .about-hero h1 {
      font-size: 2.5rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      line-height: 1.15;
      margin-bottom: 10px;
    }

    .about-hero h1 span {
      color: #8fcbff;
      position: relative;
    }

    .about-hero .tagline {
      font-size: 1.2rem;
      font-weight: 400;
      color: #d6e8ff;
      margin-bottom: 16px;
      max-width: 700px;
      opacity: 0.95;
    }

    .about-hero p {
      font-size: 1rem;
      max-width: 780px;
      color: #c8ddf5;
      opacity: 0.92;
      margin-bottom: 4px;
    }

    .about-hero p i {
      opacity: 0.9;
    }

    .about-hero p:last-of-type {
      margin-bottom: 0;
    }

    /* ----- section titles (modern) ----- */
    .section-title {
      font-size: 2.1rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      margin-bottom: 4px;
      color: #0a1f33;
    }

    .section-sub {
      color: #2a4a6e;
      font-size: 1rem;
      margin-bottom: 28px;
      padding-left: 18px;
      font-weight: 400;
      border-left: 4px solid #3b82e0;
    }

    .section-title i {
      color: #2563c0;
      margin-right: 12px;
      font-size: 1.8rem;
    }

    /* ----- cards (elevated, modern) ----- */
    .grid-3col {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-bottom: 40px;
    }

    .card {
      background: white;
      padding: 26px 24px 28px;
      box-shadow: 0 4px 16px rgba(0, 20, 40, 0.04);
      transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      border: 1px solid rgba(255, 255, 255, 0.6);
      position: relative;
      overflow: hidden;
    }

    .card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 3px;
      background: linear-gradient(90deg, #2563c0, #8fcbff);
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .card:hover::before {
      opacity: 1;
    }

    .card:hover {
      transform: translateY(-6px);
      box-shadow: 0 16px 40px rgba(37, 99, 192, 0.10);
      border-color: rgba(37, 99, 192, 0.12);
    }

    .card-icon {
      font-size: 2.4rem;
      color: #2563c0;
      margin-bottom: 12px;
      display: inline-block;
      background: #eef5fe;
      padding: 10px 12px;
      line-height: 1;
      transition: all 0.3s ease;
    }

    .card:hover .card-icon {
      background: #2563c0;
      color: white;
      transform: scale(1.05);
    }

    .card h3 {
      font-size: 1.2rem;
      font-weight: 700;
      margin-bottom: 6px;
      color: #0a1f33;
    }

    .card p {
      color: #1e344b;
      font-size: 0.95rem;
      line-height: 1.6;
      opacity: 0.9;
    }

    /* ----- approach marquee (elegant) ----- */
    .approach-wrapper {
      background: white;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.02);
      border: 1px solid #e8eef6;
      padding: 18px 0;
      margin: 12px 0 36px;
      overflow: hidden;
    }

    .marquee-steps {
      display: flex;
      align-items: center;
      gap: 20px;
      white-space: nowrap;
      animation: scrollMarquee 28s linear infinite;
      width: max-content;
    }

    .marquee-steps .step {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-weight: 600;
      color: #0a1f33;
      font-size: 1rem;
      padding: 0 6px;
    }

    .marquee-steps .step i {
      color: #2563c0;
      font-size: 1.1rem;
      background: #eef5fe;
      padding: 6px;
      border-radius: 2px;
      transition: all 0.2s;
    }

    .marquee-steps .step:hover i {
      background: #2563c0;
      color: white;
    }

    .marquee-steps .arrow {
      color: #3b82e0;
      font-weight: 300;
      margin: 0 4px;
      font-size: 1.1rem;
      opacity: 0.6;
    }

    @keyframes scrollMarquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    .approach-wrapper:hover .marquee-steps {
      animation-play-state: paused;
    }

    /* ----- industry tags (modern) ----- */
    .industry-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 10px 14px;
      background: white;
      padding: 22px 26px;
      border: 1px solid #e8eef6;
      margin-bottom: 16px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
    }

    .industry-tags span {
      background: #eef5fe;
      padding: 6px 20px;
      font-weight: 500;
      font-size: 0.85rem;
      color: #0f355a;
      transition: all 0.2s;
      cursor: default;
    }

    .industry-tags span:hover {
      background: #2563c0;
      color: white;
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(37, 99, 192, 0.20);
    }

    /* ----- why list (modern) ----- */
    .why-list {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px 24px;
      background: white;
      padding: 26px 30px;
      border: 1px solid #e8eef6;
      margin: 10px 0 24px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
    }

    .why-list li {
      list-style: none;
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 500;
      font-size: 0.95rem;
      padding: 6px 0;
      border-bottom: 1px solid rgba(0, 0, 0, 0.02);
    }

    .why-list li:last-child {
      border-bottom: none;
    }

    .why-list li i {
      color: #2563c0;
      font-size: 1.1rem;
      width: 24px;
      text-align: center;
    }

    /* ----- values (modern) ----- */
    .values-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 16px;
      background: white;
      padding: 26px 24px;
      border: 1px solid #e8eef6;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
    }

    .value-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 8px 12px;
      border-radius: 2px;
      transition: all 0.2s;
    }

    .value-item:hover {
      background: #eef5fe;
    }

    .value-item i {
      font-size: 1.4rem;
      color: #2563c0;
      width: 32px;
      text-align: center;
    }

    .value-item strong {
      font-weight: 700;
      display: block;
      font-size: 0.95rem;
    }

    .value-item span {
      font-size: 0.85rem;
      color: #2a4a6e;
    }

    /* ----- vision/mission cards (soft) ----- */
    .vision-mission {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin: 24px 0 20px;
    }

    .vision-mission .card {
      background: #eaf3fe;
      border-color: #d4e4f5;
    }

    .vision-mission .card .card-icon {
      background: #d4e4f5;
      color: #1a4d7a;
    }

    .vision-mission .card:hover .card-icon {
      background: #1a4d7a;
      color: white;
    }

    /* ----- footer (elegant) ----- */
    .footer-note {
      background: linear-gradient(135deg, #0a1f33 0%, #1a3f5e 100%);
      color: white;
      padding: 32px 0 28px;
      margin-top: 36px;
      box-shadow: 0 -8px 30px rgba(0, 0, 0, 0.05);
    }

    .footer-note .container {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .footer-note h2 {
      font-weight: 700;
      font-size: 1.9rem;
      letter-spacing: -0.02em;
      margin-bottom: 8px;
    }

    .footer-note h2 i {
      color: #8fcbff;
      margin-right: 14px;
    }

    .footer-note p {
      max-width: 620px;
      opacity: 0.85;
      font-size: 1rem;
      line-height: 1.7;
    }

    .footer-note .brand {
      margin-top: 16px;
      font-weight: 300;
      letter-spacing: 1.5px;
      color: #c2dcff;
      font-size: 1.1rem;
    }

    .footer-note .brand span {
      color: #8fcbff;
      font-weight: 400;
    }

    /* ----- responsive ----- */
    @media (max-width: 1024px) {
      .grid-3col { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 768px) {
      .about-hero h1 { font-size: 2.0rem; }
      .about-hero .tagline { font-size: 1rem; }
      .grid-3col { grid-template-columns: 1fr; }
      .why-list { grid-template-columns: 1fr; }
      .values-list { grid-template-columns: 1fr 1fr; }
      .vision-mission { grid-template-columns: 1fr; }
      .marquee-steps { gap: 12px; }
      .marquee-steps .step { font-size: 0.9rem; }
      .about-hero { padding: 24px 0 20px; }
    }

    @media (max-width: 480px) {
      .values-list { grid-template-columns: 1fr; }
      .about-hero h1 { font-size: 1.7rem; }
      .about-hero { padding: 20px 0 16px; }
    }
  </style>
</head>
<body>
  <!-- HERO -->
  <section class="about-hero">
    <div class="container">
      <div class="badge">About VedaNova</div>
      <h1>Transforming Ideas into <span>Intelligent</span> Business Solutions</h1>
      <div class="tagline">At VedaNova, we believe technology should do more than solve today's challenges—it should create opportunities for tomorrow.</div>
      <p><i class="fas fa-check-circle" style="color: #8fcbff; margin-right: 8px;"></i> Technology consulting &amp; digital transformation — modernize operations, improve decision-making, strengthen security, and accelerate growth.</p>
      <p style="margin-top: 2px;"><i class="fas fa-handshake" style="color: #8fcbff; margin-right: 8px;"></i> Strategic consulting, engineering excellence, and business understanding — solutions that are scalable, secure, and aligned with your long-term objectives.</p>
    </div>
  </section>

  <div class="container">
    <!-- What We Do -->
    <div style="margin-top: 8px;">
      <h2 class="section-title"><i class="fas fa-cubes"></i> What We Do</h2>
      <div class="section-sub">End-to-end consulting, design, implementation, and support across technology domains</div>
