    <!-- Our Approach with MARQUEE -->
    <h2 class="section-title" style="margin-top: 16px;"><i class="fas fa-sync-alt"></i> Our Approach</h2>
    <div class="section-sub">Every business is unique — we follow a structured, collaborative engagement model</div>
    
    <div class="approach-wrapper">
      <div class="marquee-steps">
        <span class="step"><i class="fas fa-eye"></i> Understand</span>
        <span class="arrow">→</span>
        <span class="step"><i class="fas fa-clipboard-check"></i> Assess</span>
