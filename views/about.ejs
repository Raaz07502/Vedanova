<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.5, user-scalable=yes" />
  <title>About VedaNova · Innovating Beyond Boundaries</title>
  <!-- Font & Icons -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />

  <link rel="stylesheet" href="/css/common/header.css">
  <link rel="stylesheet" href="/css/common/footer.css">

  <style>
    /* ----- RESET & BASE - DARK THEME ----- */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: #080d1a;
      color: #e8edf5;
      line-height: 1.6;
    }

    .container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* ----- HERO SECTION - DARK THEME (Home Page Style) ----- */
    .about-hero {
      background: linear-gradient(145deg, #080d1a 0%, #0f1a30 100%);
      color: white;
      padding: 42px 0 28px;
      margin-bottom: 28px;
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
      position: relative;
      overflow: hidden;
      border-bottom: 1px solid rgba(0, 212, 255, 0.05);
    }

    .about-hero::before {
      content: '';
      position: absolute;
      top: -50%;
      right: -20%;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(0, 212, 255, 0.05) 0%, transparent 70%);
      border-radius: 50%;
      pointer-events: none;
    }

    .about-hero::after {
      content: '';
      position: absolute;
      bottom: -30%;
      left: -10%;
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(123, 47, 252, 0.04) 0%, transparent 70%);
      border-radius: 50%;
      pointer-events: none;
    }

    .about-hero .container {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      position: relative;
      z-index: 1;
    }

    .about-hero .badge {
      display: inline-block;
      background: rgba(0, 212, 255, 0.06);
      backdrop-filter: blur(8px);
      padding: 5px 18px;
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.6px;
      text-transform: uppercase;
      color: #8aa8c9;
      margin-bottom: 14px;
      border: 1px solid rgba(0, 212, 255, 0.08);
      border-radius: 30px;
    }

    .about-hero h1 {
      font-size: 2.5rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      line-height: 1.15;
      margin-bottom: 10px;
    }

    .about-hero h1 span {
      background: linear-gradient(135deg, #00d4ff, #7b2ffc);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      position: relative;
    }

    .about-hero .tagline {
      font-size: 1.2rem;
      font-weight: 400;
      color: #8aa8c9;
      margin-bottom: 16px;
      max-width: 700px;
      opacity: 0.95;
    }

    .about-hero p {
      font-size: 1rem;
      max-width: 780px;
      color: #8aa8c9;
      opacity: 0.92;
      margin-bottom: 4px;
    }

    .about-hero p i {
      opacity: 0.9;
      color: #00d4ff !important;
    }

    .about-hero p:last-of-type {
      margin-bottom: 0;
    }

    /* ----- SECTION TITLES - DARK THEME ----- */
    .section-title {
      font-size: 2.1rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      margin-bottom: 4px;
      background: linear-gradient(135deg, #ffffff 0%, #00d4ff 100%);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .section-sub {
      color: #8aa8c9;
      font-size: 1rem;
      margin-bottom: 28px;
      padding-left: 18px;
      font-weight: 400;
      border-left: 4px solid #00d4ff;
    }

    .section-title i {
      background: linear-gradient(135deg, #00d4ff, #7b2ffc);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-right: 12px;
      font-size: 1.8rem;
    }

    /* ----- CARDS - DARK THEME ----- */
    .grid-3col {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-bottom: 40px;
    }

    .card {
      background: rgba(255, 255, 255, 0.03);
      backdrop-filter: blur(10px);
      padding: 26px 24px 28px;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
      transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      border: 1px solid rgba(0, 212, 255, 0.05);
      position: relative;
      overflow: hidden;
      border-radius: 1.5rem;
    }

    .card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 3px;
      background: linear-gradient(90deg, #00d4ff, #7b2ffc);
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .card:hover::before {
      opacity: 1;
    }

    .card:hover {
      transform: translateY(-6px);
      box-shadow: 0 16px 40px rgba(0, 212, 255, 0.06);
      border-color: rgba(0, 212, 255, 0.12);
    }

    .card-icon {
      font-size: 2.4rem;
      color: #00d4ff;
      margin-bottom: 12px;
      display: inline-block;
      background: rgba(0, 212, 255, 0.06);
      padding: 10px 12px;
      line-height: 1;
      transition: all 0.3s ease;
      border-radius: 14px;
    }

    .card:hover .card-icon {
      background: linear-gradient(135deg, #00d4ff, #7b2ffc);
      color: white;
      transform: scale(1.05);
    }

    .card h3 {
      font-size: 1.2rem;
      font-weight: 700;
      margin-bottom: 6px;
      color: #e8edf5;
    }

    .card p {
      color: #8aa8c9;
      font-size: 0.95rem;
      line-height: 1.6;
      opacity: 0.9;
    }

    /* ----- APPROACH MARQUEE - DARK THEME ----- */
    .approach-wrapper {
      background: rgba(255, 255, 255, 0.03);
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
      border: 1px solid rgba(0, 212, 255, 0.05);
      padding: 18px 0;
      margin: 12px 0 36px;
      overflow: hidden;
      border-radius: 1rem;
    }

    .marquee-steps {
      display: flex;
      align-items: center;
      gap: 20px;
      white-space: nowrap;
      animation: scrollMarquee 28s linear infinite;
      width: max-content;
    }

    .marquee-steps .step {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-weight: 600;
      color: #e8edf5;
      font-size: 1rem;
      padding: 0 6px;
    }

    .marquee-steps .step i {
      color: #00d4ff;
      font-size: 1.1rem;
      background: rgba(0, 212, 255, 0.06);
      padding: 6px;
      border-radius: 8px;
      transition: all 0.2s;
    }

    .marquee-steps .step:hover i {
      background: linear-gradient(135deg, #00d4ff, #7b2ffc);
      color: white;
    }

    .marquee-steps .arrow {
      color: #00d4ff;
      font-weight: 300;
      margin: 0 4px;
      font-size: 1.1rem;
      opacity: 0.4;
    }

    @keyframes scrollMarquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    .approach-wrapper:hover .marquee-steps {
      animation-play-state: paused;
    }

    /* ----- INDUSTRY TAGS - DARK THEME ----- */
    .industry-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 10px 14px;
      background: rgba(255, 255, 255, 0.03);
      padding: 22px 26px;
      border: 1px solid rgba(0, 212, 255, 0.05);
      margin-bottom: 16px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
      border-radius: 1rem;
    }

    .industry-tags span {
      background: rgba(0, 212, 255, 0.06);
      padding: 6px 20px;
      font-weight: 500;
      font-size: 0.85rem;
      color: #8aa8c9;
      transition: all 0.2s;
      cursor: default;
      border-radius: 30px;
      border: 1px solid rgba(0, 212, 255, 0.04);
    }

    .industry-tags span:hover {
      background: linear-gradient(135deg, #00d4ff, #7b2ffc);
      color: white;
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(0, 212, 255, 0.2);
    }

    /* ----- WHY LIST - DARK THEME ----- */
    .why-list {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px 24px;
      background: rgba(255, 255, 255, 0.03);
      padding: 26px 30px;
      border: 1px solid rgba(0, 212, 255, 0.05);
      margin: 10px 0 24px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
      border-radius: 1rem;
    }

    .why-list li {
      list-style: none;
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 500;
      font-size: 0.95rem;
      padding: 6px 0;
      border-bottom: 1px solid rgba(0, 212, 255, 0.04);
      color: #c8ddf5;
    }

    .why-list li:last-child {
      border-bottom: none;
    }

    .why-list li i {
      color: #00d4ff;
      font-size: 1.1rem;
      width: 24px;
      text-align: center;
    }

    /* ----- VALUES - DARK THEME ----- */
    .values-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 16px;
      background: rgba(255, 255, 255, 0.03);
      padding: 26px 24px;
      border: 1px solid rgba(0, 212, 255, 0.05);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
      border-radius: 1rem;
    }

    .value-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 8px 12px;
      border-radius: 12px;
      transition: all 0.2s;
    }

    .value-item:hover {
      background: rgba(0, 212, 255, 0.04);
    }

    .value-item i {
      font-size: 1.4rem;
      color: #00d4ff;
      width: 32px;
      text-align: center;
    }

    .value-item strong {
      font-weight: 700;
      display: block;
      font-size: 0.95rem;
      color: #e8edf5;
    }

    .value-item span {
      font-size: 0.85rem;
      color: #8aa8c9;
    }

    /* ----- VISION/MISSION CARDS - DARK THEME ----- */
    .vision-mission {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin: 24px 0 20px;
    }

    .vision-mission .card {
      background: rgba(0, 212, 255, 0.04);
      border-color: rgba(0, 212, 255, 0.08);
    }

    .vision-mission .card .card-icon {
      background: rgba(0, 212, 255, 0.08);
      color: #00d4ff;
    }

    .vision-mission .card:hover .card-icon {
      background: linear-gradient(135deg, #00d4ff, #7b2ffc);
      color: white;
    }

    /* ----- RESPONSIVE - SAME AS ORIGINAL ----- */
    @media (max-width: 1024px) {
      .grid-3col { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 768px) {
      .about-hero h1 { font-size: 2.0rem; }
      .about-hero .tagline { font-size: 1rem; }
      .grid-3col { grid-template-columns: 1fr; }
      .why-list { grid-template-columns: 1fr; }
      .values-list { grid-template-columns: 1fr 1fr; }
      .vision-mission { grid-template-columns: 1fr; }
      .marquee-steps { gap: 12px; }
      .marquee-steps .step { font-size: 0.9rem; }
      .about-hero { padding: 24px 0 20px; }
      .section-title { font-size: 1.8rem; }
    }

    @media (max-width: 480px) {
      .values-list { grid-template-columns: 1fr; }
      .about-hero h1 { font-size: 1.7rem; }
      .about-hero { padding: 20px 0 16px; }
      .about-hero .badge { font-size: 0.6rem; padding: 4px 12px; }
      .industry-tags { padding: 16px; }
      .why-list { padding: 18px; }
      .card { padding: 20px 16px; }
      .container { padding: 0 16px; }
      .section-sub { padding-left: 12px; }
    }

    @media (max-width: 360px) {
      .about-hero h1 { font-size: 1.4rem; }
      .marquee-steps .step { font-size: 0.75rem; gap: 4px; }
      .marquee-steps .step i { font-size: 0.9rem; padding: 4px; }
    }
  </style>
</head>
<body>

