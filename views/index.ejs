<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AnyTechPros</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;500;600;700&display=swap"
        rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/common/header.css">
    <link rel="stylesheet" href="/css/common/footer.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>
      /* ============================================================
   DARK THEME - Nexalogic Style
   ============================================================ */

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Inter', sans-serif;
    background: #080d1a;
    color: #e8edf5;
    scroll-behavior: smooth;
}

/* ===== CAROUSEL ===== */
.carousel-inner,
.carousel-item {
    height: 64vh;
}
.carousel-item img {
    height: 100%;
    width: 100%;
    object-fit: cover;
}

/* ===== HERO TITLE SECTION ===== */
.hero-title-section {
    text-align: center;
    padding: 3rem 1.5rem 1.5rem 1.5rem;
    background: linear-gradient(135deg, #0a1225 0%, #111d3a 100%);
}
.hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: linear-gradient(135deg, #1a3a6a 0%, #0f284a 100%);
    padding: 0.6rem 1.5rem;
    border-radius: 80px;
    margin-bottom: 0.5rem;
    border: 1px solid rgba(0, 212, 255, 0.15);
}
.hero-badge i {
    font-size: 2rem;
    color: #00d4ff;
}
.hero-badge span {
    font-size: 1.8rem;
    font-weight: 800;
    letter-spacing: 2px;
    background: linear-gradient(135deg, #00d4ff, #7b2ffc);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-transform: uppercase;
}
.hero-subtitle {
    font-size: 1rem;
    color: #8aa8c9;
    margin-top: 0.75rem;
    font-weight: 500;
}

/* ===== CAPABILITY SECTION (Cards) ===== */
.capability-section {
    padding: 0rem 1.5rem 5rem 1.5rem;
    background: linear-gradient(135deg, #080d1a 0%, #0f1a30 100%);
}
.showcase-grid {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.8rem;
    align-items: stretch;
}
.challenges,
.capability-depth {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(10px);
    border-radius: 1.5rem;
    box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.4);
    padding: 2rem 2rem;
    transition: all 0.35s ease;
    border: 1px solid rgba(0, 212, 255, 0.08);
    position: relative;
    overflow: hidden;
}
.challenges::before,
.capability-depth::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, #00d4ff, #7b2ffc);
    transform: scaleX(0);
    transition: transform 0.4s ease;
}
.challenges:hover::before,
.capability-depth:hover::before {
    transform: scaleX(1);
}
.challenges:hover,
.capability-depth:hover {
    transform: translateY(-6px);
    box-shadow: 0 28px 45px -18px rgba(0, 212, 255, 0.15);
    border-color: rgba(0, 212, 255, 0.2);
}
.section-label {
    font-size: 0.75rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-weight: 700;
    color: #00d4ff;
    background: rgba(0, 212, 255, 0.1);
    display: inline-block;
    padding: 0.3rem 1rem;
    border-radius: 30px;
    margin-bottom: 1rem;
}
.section-title {
    font-size: 1.9rem;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 0.75rem;
    color: #e8edf5;
    letter-spacing: -0.02em;
}
.section-sub {
    font-size: 0.95rem;
    color: #8aa8c9;
    border-left: 3px solid #00d4ff;
    padding-left: 1rem;
    margin-bottom: 1.8rem;
    font-weight: 500;
}
.feature-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 0.5rem;
}
.feature-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    transition: all 0.2s;
}
.feature-icon {
    font-size: 1.4rem;
    font-weight: 800;
    min-width: 48px;
    background: rgba(0, 212, 255, 0.08);
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    color: #00d4ff;
    transition: 0.25s;
}
.feature-item:hover .feature-icon {
    background: linear-gradient(135deg, #00d4ff, #7b2ffc);
    color: white;
    transform: scale(1.02);
}
.feature-text h3 {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 0.35rem;
    color: #e8edf5;
}
.feature-text p {
    font-size: 0.88rem;
    color: #8aa8c9;
    line-height: 1.45;
    margin: 0;
}
.skill-bars {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    margin-top: 0.8rem;
}
.skill-item {
    width: 100%;
}
.skill-info {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.5rem;
    font-weight: 600;
    font-size: 0.9rem;
}
.skill-name {
    color: #c8ddf5;
    font-weight: 600;
}
.skill-percent {
    color: #00d4ff;
    font-weight: 800;
    background: rgba(0, 212, 255, 0.1);
    padding: 0.2rem 0.7rem;
    border-radius: 20px;
    font-size: 0.75rem;
}
.progress-bar-bg {
    background-color: rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    height: 8px;
    overflow: hidden;
}
.progress-fill {
    background: linear-gradient(90deg, #00d4ff, #7b2ffc);
    width: 100%;
    height: 100%;
    border-radius: 12px;
    transition: width 1s cubic-bezier(0.2, 0.9, 0.4, 1.1);
}

/* ===== STATS SECTION ===== */
.stats-section {
    background: linear-gradient(135deg, #080d1a 0%, #0f1a30 100%);
    padding: 1.5rem 1.5rem;
    position: relative;
    border-top: 1px solid rgba(0, 212, 255, 0.05);
    border-bottom: 1px solid rgba(0, 212, 255, 0.05);
}
.stats-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0rem;
}
.stat-card {
    text-align: center;
    flex: 1;
    min-width: 180px;
    padding: 1rem 1.5rem;
    transition: transform 0.3s ease;
    position: relative;
}
.stat-card:not(:last-child)::after {
    content: '';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 2px;
    height: 50px;
    background: linear-gradient(180deg, transparent, rgba(0, 212, 255, 0.3), transparent);
}
.stat-card:hover {
    transform: translateY(-8px);
}
.stat-number {
    font-size: 3.5rem;
    font-weight: 800;
    background: linear-gradient(135deg, #00d4ff 0%, #7b2ffc 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
}
.stat-number span {
    background: linear-gradient(135deg, #00d4ff 0%, #7b2ffc 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
}
.stat-label {
    font-size: 0.8rem;
    letter-spacing: 2.5px;
    font-weight: 700;
    color: #8aa8c9;
    text-transform: uppercase;
    opacity: 0.85;
}

/* ===== NEW HOME HERO SECTION ===== */
.home-hero-section {
    position: relative;
    background: linear-gradient(135deg, #080d1a 0%, #0f1a30 100%);
    overflow: hidden;
    padding: 3rem 2rem 1.5rem 2rem;
    min-height: 70vh;
    display: flex;
    align-items: center;
}
.hero-background-shape {
    position: absolute;
    top: -30%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(0, 212, 255, 0.05) 0%, rgba(0, 212, 255, 0) 70%);
    border-radius: 50%;
    z-index: 0;
}
.hero-container {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    position: relative;
    z-index: 2;
}
.hero-content {
    max-width: 600px;
}
.hero-badge-new {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: rgba(0, 212, 255, 0.06);
    backdrop-filter: blur(4px);
    padding: 0.5rem 1.2rem;
    border-radius: 100px;
    margin-bottom: 1.8rem;
    border: 1px solid rgba(0, 212, 255, 0.15);
}
.badge-pulse {
    width: 10px;
    height: 10px;
    background: #00d4ff;
    border-radius: 50%;
    box-shadow: 0 0 0 0 rgba(0, 212, 255, 0.5);
    animation: pulse 1.5s infinite;
}
@keyframes pulse {
    0% { transform: scale(0.9); box-shadow: 0 0 0 0 rgba(0, 212, 255, 0.5); }
    70% { transform: scale(1); box-shadow: 0 0 0 8px rgba(0, 212, 255, 0); }
    100% { transform: scale(0.9); box-shadow: 0 0 0 0 rgba(0, 212, 255, 0); }
}
.badge-text {
    font-size: 0.8rem;
    font-weight: 600;
    color: #8aa8c9;
    letter-spacing: 0.5px;
}

/* ★ MAIN TITLE - DARK THEME ★ */
.hero-main-title {
    font-family: 'Zodiak', 'Times New Roman', serif;
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.25;
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
    background: linear-gradient(110deg, #ffffff 0%, #00d4ff 70%, #7b2ffc 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
}

.hero-description {
    font-size: 1.1rem;
    line-height: 1.6;
    color: #8aa8c9;
    margin-bottom: 2rem;
    font-weight: 400;
}
.hero-buttons {
    display: flex;
    gap: 1.2rem;
    margin-bottom: 2.5rem;
}
.btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: linear-gradient(135deg, #00d4ff 0%, #7b2ffc 100%);
    color: white;
    padding: 0.9rem 2rem;
    border-radius: 50px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 10px 20px -8px rgba(0, 212, 255, 0.3);
}
.btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 25px -10px rgba(0, 212, 255, 0.4);
    color: white;
}
.trust-indicators {
    display: flex;
    gap: 2rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
}
.trust-item {
    text-align: left;
}
.trust-number {
    font-size: 1.8rem;
    font-weight: 800;
    background: linear-gradient(135deg, #00d4ff, #7b2ffc);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    line-height: 1.2;
}
.trust-label {
    font-size: 0.75rem;
    color: #8aa8c9;
    letter-spacing: 1px;
    font-weight: 500;
}

/* ===== RIGHT VISUAL CARD ===== */
.hero-right {
    display: flex;
    justify-content: center;
    align-items: center;
}
.hero-visual-card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(2px);
    border-radius: 2rem;
    padding: 1.4rem 1.8rem;
    box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(0, 212, 255, 0.12);
    width: 100%;
    transition: all 0.3s ease;
    text-align: center;
}
.hero-visual-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 30px 45px -12px rgba(0, 212, 255, 0.15);
    border-color: rgba(0, 212, 255, 0.25);
}
.map-illustration i {
    font-size: 3.8rem;
    color: #00d4ff;
    background: rgba(0, 212, 255, 0.06);
    padding: 0.8rem;
    border-radius: 80px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    margin-bottom: 0.75rem;
}
.map-illustration div:first-of-type {
    font-weight: 800;
    font-size: 1.15rem;
    margin: 0.5rem 0 0.25rem;
    color: #e8edf5;
}
.state-list {
    font-size: 0.78rem;
    color: #8aa8c9;
    line-height: 1.4;
    font-weight: 500;
    background: rgba(255, 255, 255, 0.04);
    padding: 0.4rem 0.6rem;
    border-radius: 40px;
    display: inline-block;
    margin: 0.5rem auto;
}
.capability-pills {
    display: flex;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 1rem;
}
.pill {
    background: rgba(0, 212, 255, 0.06);
    padding: 0.3rem 0.9rem;
    border-radius: 40px;
    font-size: 0.7rem;
    font-weight: 700;
    color: #8aa8c9;
    letter-spacing: 0.3px;
    transition: 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    border: 1px solid rgba(0, 212, 255, 0.05);
}
.pill i {
    font-size: 0.7rem;
    color: #00d4ff;
    background: transparent;
    box-shadow: none;
    padding: 0;
    margin: 0;
}
.pill:hover {
    background: linear-gradient(135deg, #00d4ff, #7b2ffc);
    color: white;
    transform: scale(1.02);
}
.pill:hover i {
    color: white;
}
.hero-visual-card hr {
    margin: 1rem 0 0.8rem;
    opacity: 0.1;
    border-color: rgba(255,255,255,0.05);
}

/* ============================================================
   RESPONSIVE BREAKPOINTS
   ============================================================ */

@media (max-width: 992px) {
    .showcase-grid {
        grid-template-columns: 1fr;
        gap: 1.8rem;
    }
    .capability-section {
        padding: 0rem 1.25rem 3.5rem 1.25rem;
    }
    .section-title {
        font-size: 1.7rem;
    }
    .hero-badge span {
        font-size: 1.3rem;
    }
    .hero-badge i {
        font-size: 1.5rem;
    }
    .hero-badge {
        padding: 0.6rem 1.8rem;
    }
    .hero-container {
        grid-template-columns: 1fr;
        text-align: center;
        gap: 2rem;
    }
    .hero-content {
        max-width: 100%;
        text-align: center;
    }
    .hero-buttons {
        justify-content: center;
    }
    .trust-indicators {
        justify-content: center;
    }
    .trust-item {
        text-align: center;
    }
    .home-hero-section {
        padding: 2rem 1.5rem 3rem 1.5rem;
        min-height: auto;
    }
    .hero-main-title {
        font-size: 2.2rem;
    }
}

@media (max-width: 768px) {
    .challenges,
    .capability-depth {
        padding: 1.5rem;
    }
    .section-title {
        font-size: 1.5rem;
    }
    .hero-title-section {
        padding: 2rem 1rem 1rem 1rem;
    }
    .hero-badge span {
        font-size: 1.1rem;
        letter-spacing: 1px;
    }
    .hero-badge {
        padding: 0.5rem 1.2rem;
        gap: 8px;
    }
    .hero-badge i {
        font-size: 1.2rem;
    }
    .hero-description {
        font-size: 1rem;
    }
    .hero-buttons {
        flex-direction: column;
        align-items: center;
        gap: 1rem;
    }
    .btn-primary {
        width: 100%;
        justify-content: center;
    }
    .trust-number {
        font-size: 1.4rem;
    }
    .trust-label {
        font-size: 0.7rem;
    }
    .hero-main-title {
        font-size: 1.8rem;
        line-height: 1.3;
    }
    .stats-container {
        justify-content: center;
        gap: 1.5rem;
    }
    .stat-card {
        min-width: 160px;
        padding: 0.8rem 1rem;
    }
    .stat-card:not(:last-child)::after {
        display: none;
    }
    .stat-number {
        font-size: 2.8rem;
    }
    .stat-number span {
        font-size: 1.8rem;
    }
    .stat-label {
        font-size: 0.7rem;
        letter-spacing: 1.5px;
    }
}

@media (max-width: 576px) {
    .feature-icon {
        width: 40px;
        height: 40px;
        font-size: 1.3rem;
        min-width: 40px;
    }
    .feature-text h3 {
        font-size: 1rem;
    }
    .feature-text p {
        font-size: 0.8rem;
    }
    .section-title {
        font-size: 1.4rem;
    }
    .skill-name {
        font-size: 0.8rem;
    }
    .skill-percent {
        font-size: 0.7rem;
    }
    .stat-card {
        min-width: 140px;
    }
    .stat-number {
        font-size: 2.2rem;
    }
    .stat-number span {
        font-size: 1.4rem;
    }
    .hero-description {
        font-size: 0.9rem;
    }
    .trust-indicators {
        gap: 1rem;
    }
    .trust-number {
        font-size: 1.2rem;
    }
    .trust-label {
        font-size: 0.6rem;
    }
    .hero-badge-new {
        padding: 0.4rem 1rem;
    }
    .badge-text {
        font-size: 0.7rem;
    }
    .hero-main-title {
        font-size: 1.4rem;
        line-height: 1.35;
    }
}

/* ============================================================
   WHO WE ARE SECTION - DARK THEME
   ============================================================ */

.who-we-are-section {
    padding: 4rem 2rem 1.5rem 2rem;
    background: #080d1a;
    border-bottom: 1px solid rgba(0, 212, 255, 0.05);
}

.who-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    align-items: start;
}

.who-left {
    padding-top: 0.5rem;
}

.who-tag {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: #00d4ff;
    margin-bottom: 0.75rem;
}

.who-tag-line {
    display: inline-block;
    width: 40px;
    height: 3px;
    background: linear-gradient(90deg, #00d4ff, #7b2ffc);
    border-radius: 4px;
}

.who-heading {
    font-family: 'Zodiak', 'Times New Roman', serif;
    font-size: 2.8rem;
    font-weight: 700;
    line-height: 1.15;
    background: linear-gradient(135deg, #ffffff 0%, #00d4ff 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin: 0;
    letter-spacing: -0.02em;
}

.who-right {
    padding-top: 0.5rem;
}

.who-description {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #8aa8c9;
    margin-bottom: 1.5rem;
    font-weight: 400;
    max-width: 650px;
}

.who-tagline {
    font-size: 1.05rem;
    font-weight: 700;
    color: #00d4ff;
    letter-spacing: 0.5px;
    padding-left: 1.2rem;
    border-left: 4px solid #00d4ff;
    line-height: 1.4;
}

.who-image-wrapper {
    width: 100%;
    border-radius: 1.5rem;
    overflow: hidden;
    box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(0, 212, 255, 0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.who-image-wrapper:hover {
    transform: translateY(-6px);
    box-shadow: 0 28px 50px -16px rgba(0, 212, 255, 0.1);
}

.who-image-wrapper img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: 4 / 3;
    background: #0a1225;
}

@media (max-width: 992px) {
    .who-container {
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }
    .who-heading {
        font-size: 2.2rem;
    }
    .who-description {
        font-size: 1rem;
        max-width: 100%;
    }
    .who-we-are-section {
        padding: 3rem 1.5rem;
    }
    .who-image-wrapper img {
        aspect-ratio: 16 / 9;
    }
}

@media (max-width: 768px) {
    .who-heading {
        font-size: 1.8rem;
    }
    .who-description {
        font-size: 0.95rem;
    }
    .who-tagline {
        font-size: 0.9rem;
        padding-left: 1rem;
    }
    .who-tag {
        font-size: 0.75rem;
    }
    .who-we-are-section {
        padding: 2.5rem 1.25rem;
    }
}

@media (max-width: 576px) {
    .who-heading {
        font-size: 1.5rem;
    }
    .who-description {
        font-size: 0.9rem;
        line-height: 1.6;
    }
    .who-tagline {
        font-size: 0.85rem;
        padding-left: 0.8rem;
